# LLM Provider: "openai", "groq", or "ollama"
LLM_PROVIDER=ollama

# Groq (required if LLM_PROVIDER=groq) — free tier: console.groq.com
GROQ_API_KEY=gsk-your-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here

# Ollama (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embeddings (all-MiniLM-L6-v2, o paraphrase-multilingual-mpnet-base-v2 para multilingüe)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ChromaDB
CHROMA_DB_PATH=./chroma_db
COLLECTION_NAME=support_docs

# Search
SIMILARITY_THRESHOLD=0.5
TOP_K_RESULTS=5

# API
API_HOST=0.0.0.0
API_PORT=8000
